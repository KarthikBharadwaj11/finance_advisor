# ─── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.0

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://advisor:secret@localhost:5432/financeadv

# ─── Vector Store ─────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=faiss_index

# ─── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_RENDERER=console          # json | console
MAX_AGENT_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=60
CORS_ORIGINS=["http://localhost:3000"]

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
